{
  "enabled": false,
  "provider": "openai",
  "client_module": "src/narrative_dna/llm_client.py",
  "main_classifier": {
    "model": "gpt-5.5",
    "reasoning_effort": "low",
    "text_verbosity": "low",
    "max_output_tokens": 1200,
    "timeout_seconds": 60
  },
  "adjudicator": {
    "model": "gpt-5.5",
    "reasoning_effort": "high",
    "text_verbosity": "low",
    "max_output_tokens": 1200,
    "timeout_seconds": 60
  },
  "synthetic_reviewers": [
    {
      "name": "divergent_reviewer_a",
      "model": "gpt-5.5",
      "reasoning_effort": "high",
      "text_verbosity": "medium"
    },
    {
      "name": "divergent_reviewer_b",
      "model": "gpt-5.5",
      "reasoning_effort": "high",
      "text_verbosity": "medium"
    },
    {
      "name": "taxonomy_strict_reviewer",
      "model": "gpt-5.5",
      "reasoning_effort": "high",
      "text_verbosity": "low"
    }
  ],
  "synthetic_aggregator": {
    "model": "gpt-5.5",
    "reasoning_effort": "high",
    "text_verbosity": "low"
  },
  "synthetic_final_adjudicator": {
    "model": "gpt-5.5",
    "reasoning_effort": "xhigh",
    "text_verbosity": "low"
  },
  "cheap_batch_profile": {
    "enabled": false,
    "model": "gpt-5.4-mini",
    "reasoning_effort": "low",
    "text_verbosity": "low",
    "max_output_tokens": 1200,
    "timeout_seconds": 60
  },
  "cache": {
    "enabled": true,
    "dir": ".cache/narrative_dna",
    "key_fields": [
      "model",
      "reasoning_effort",
      "effective_temperature",
      "text_verbosity",
      "max_output_tokens",
      "timeout_seconds",
      "input_payload",
      "input_hash",
      "taxonomy_version",
      "prompt_version",
      "validator_version"
    ]
  },
  "retry": {
    "max_attempts": 3,
    "backoff_seconds": [2, 8, 20]
  }
}
