{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/narrative_dna/unit.schema.json",
  "title": "NarrativeDNAUnit",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "document_id",
    "unit_id",
    "text",
    "functions",
    "primary_function",
    "secondary_functions",
    "inherited_functions",
    "certainty",
    "emotion_expressed",
    "emotion_intensity",
    "emotions_mentioned",
    "stance",
    "target",
    "speech_act",
    "evidence_spans",
    "rejected_labels",
    "validator_flags",
    "review_status",
    "final_notation",
    "taxonomy_version",
    "prompt_version",
    "validator_version",
    "taxonomy_version_effective",
    "prompt_version_effective",
    "validator_version_effective"
  ],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "document_id": { "type": "string", "minLength": 1 },
    "unit_id": { "type": "string", "minLength": 1 },
    "text": { "type": "string" },
    "span": { "type": "object" },
    "functions": { "type": "array", "items": { "type": "string" } },
    "primary_function": { "type": "string" },
    "secondary_functions": { "type": "array", "items": { "type": "string" } },
    "inherited_functions": { "type": "array", "items": { "type": "string" } },
    "certainty": { "type": "string" },
    "emotion_expressed": { "type": "string" },
    "emotion_intensity": { "type": "integer", "minimum": 0, "maximum": 3 },
    "emotions_mentioned": { "type": "array", "items": { "type": "string" } },
    "stance": { "type": "string" },
    "target": { "type": "string" },
    "speech_act": { "type": "string" },
    "logic": { "type": ["object", "null"] },
    "evidence_spans": { "type": "array", "items": { "type": "object" } },
    "rejected_labels": { "type": "array", "items": { "type": "object" } },
    "validator_flags": { "type": "array", "items": { "type": "object" } },
    "review_status": { "type": "string" },
    "final_notation": { "type": "string" },
    "taxonomy_version": { "type": "string" },
    "prompt_version": { "type": "string" },
    "validator_version": { "type": "string" },
    "taxonomy_version_effective": { "type": "string" },
    "prompt_version_effective": { "type": "string" },
    "validator_version_effective": { "type": "string" }
  }
}
