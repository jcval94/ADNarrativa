    "FunctionCode": {
      "enum": [
        "A",
        "K",
        "O",
        "F",
        "Y",
        "D",
        "Q",
        "P",
        "R",
        "E",
        "H",
        "G",
        "C",
        "B",
        "X",
        "T",
        "M",
        "L",
        "Z",
        "S",
        "I",
        "U",
        "V",
        "N"
