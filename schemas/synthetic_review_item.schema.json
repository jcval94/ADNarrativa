{
  "additionalProperties": false,
  "properties": {
    "review_item_id": {
      "minLength": 1,
      "title": "Review Item Id",
      "type": "string"
    },
    "item_type": {
      "enum": [
        "unit",
        "similar_pair",
        "minimal_pair",
        "relation",
        "chain"
      ],
      "title": "Item Type",
      "type": "string"
    },
    "document_id": {
      "minLength": 1,
      "title": "Document Id",
      "type": "string"
    },
    "unit_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Unit Id"
    },
    "unit_ids": {
      "items": {
        "type": "string"
      },
      "title": "Unit Ids",
      "type": "array"
    },
    "text": {
      "minLength": 1,
      "title": "Text",
      "type": "string"
    },
    "context_before": {
      "items": {
        "type": "string"
      },
      "title": "Context Before",
      "type": "array"
    },
    "context_after": {
      "items": {
        "type": "string"
      },
      "title": "Context After",
      "type": "array"
    },
    "current_prediction_json": {
      "additionalProperties": true,
      "title": "Current Prediction Json",
      "type": "object"
    },
    "current_notation": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Current Notation"
    },
    "relevant_taxonomy_rules": {
      "items": {
        "additionalProperties": true,
        "type": "object"
      },
      "title": "Relevant Taxonomy Rules",
      "type": "array"
    },
    "relevant_decision_tree": {
      "default": "",
      "title": "Relevant Decision Tree",
      "type": "string"
    },
    "relevant_minimal_pairs": {
      "items": {
        "additionalProperties": true,
        "type": "object"
      },
      "title": "Relevant Minimal Pairs",
      "type": "array"
    },
    "validator_flags": {
      "items": {
        "additionalProperties": true,
        "type": "object"
      },
      "title": "Validator Flags",
      "type": "array"
    },
    "similarity_conflict_info": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Similarity Conflict Info"
    },
    "expected_difficulty": {
      "enum": [
        "easy",
        "medium",
        "hard",
        "adversarial"
      ],
      "title": "Expected Difficulty",
      "type": "string"
    },
    "review_goal": {
      "enum": [
        "validate",
        "find_alternative",
        "resolve_confusion",
        "test_boundary"
      ],
      "title": "Review Goal",
      "type": "string"
    },
    "taxonomy_version_effective": {
      "minLength": 1,
      "title": "Taxonomy Version Effective",
      "type": "string"
    },
    "prompt_version_effective": {
      "minLength": 1,
      "title": "Prompt Version Effective",
      "type": "string"
    },
    "validator_version_effective": {
      "minLength": 1,
      "title": "Validator Version Effective",
      "type": "string"
    }
  },
  "required": [
    "review_item_id",
    "item_type",
    "document_id",
    "text",
    "expected_difficulty",
    "review_goal",
    "taxonomy_version_effective",
    "prompt_version_effective",
    "validator_version_effective"
  ],
  "title": "SyntheticReviewItem",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
